# ─────────────────────────────────────────────────────────────────────────────
# OpenAgentOS environment. Copy to `.env` and fill in your values:
#     cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# 说明:OPENAI_* 是全局兜底。每助手的 model/prompt/api_key/base_url 写在 Aegra
# assistant 的 config.configurable 里,缺项才回退到这里;MCP servers 写在共享磁盘
# workspace/.deepagent/<assistant_id>/.mcp.json。详见 README。

# ── LLM: OpenAI-compatible gateway (Azure OpenAI / LiteLLM / vLLM / Ollama) ──
OPENAI_BASE_URL=https://your-gateway.example.com/v1
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4o

# ── Optional: web search for the research subagent ──
# TAVILY_API_KEY=tvly-replace-me

# ── 官方中间件(韧性/成本/合规;retry 默认开,其余默认关)──
# AGENTOS_MODEL_MAX_RETRIES=2                    # 模型调用失败重试次数(0 关闭)
# AGENTOS_TOOL_MAX_RETRIES=2                     # 工具调用失败重试次数(0 关闭)
# AGENTOS_TOOL_CALL_LIMIT=                       # 每 run 工具调用上限(留空=不限)
# AGENTOS_FALLBACK_MODEL=                        # 主模型失败时回退的模型名(同网关;每助手可在 config 覆盖)
# AGENTOS_PII_STRATEGY=off                       # PII 脱敏:off/redact/mask/hash/block(邮箱/卡号/IP/MAC)
# AGENTOS_CONTEXT_EDITING=true                    # 上下文裁剪(按 token 阈值清旧工具输出;默认开,阈值内不触发)
# AGENTOS_TOOL_SELECTOR_MAX=                      # 工具数多时用 LLM 每轮选 N 个工具(留空=关)
# 每 run 模型调用上限(steps)与自审(review.rubric)是每助手项:放 assistant config.configurable,无全局 env。

# ── Aegra / Postgres ──
# `uv run aegra dev` provisions PostgreSQL automatically; no value needed for
# local development. For production, configure per the Aegra docs.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aegra

# ── 共享磁盘(app 与所有沙箱共用)──
# 布局:.deepagent/<assistant_id>/{skills,.mcp.json} + <assistant_id>/<thread_id>/
AGENTOS_WORKSPACE=workspace
# app 与沙箱运行时不同机/容器时,沙箱 bind mount 用的宿主绝对路径(缺省=AGENTOS_WORKSPACE 的绝对路径)
# AGENTOS_WORKSPACE_HOST=/data/agentos/workspace
# Kubernetes 部署改用 PVC(设了则优先于 host 路径)
# AGENTOS_WORKSPACE_CLAIM=agentos-workspace
# 下载链接前缀(share_file 工具与 /files 路由;缺省相对路径)
# AGENTOS_PUBLIC_URL=https://your-aegra-host

# ── 长期记忆(默认开启)──
# /memories/ 经 CompositeBackend 路由到 Aegra 的持久 store(按 assistant 隔离,跨线程共享);
# 启动加载 /memories/AGENTS.md,agent 用 edit_file 自维护。设 false 关闭。
# AGENTOS_MEMORY_ENABLED=true

# ── 每线程临时沙箱(OpenSandbox;到期由服务端自动销毁,文件在共享磁盘上持久)──
# 需先启动 OpenSandbox 服务器:
#   uvx opensandbox-server init-config ~/.sandbox.toml --example docker
#   uvx opensandbox-server                      # 默认 localhost:8080(依赖 Docker)
AGENTOS_SANDBOX_ENABLED=true
OPEN_SANDBOX_DOMAIN=localhost:8080
# OPEN_SANDBOX_API_KEY=...                      # 服务器需鉴权时填
AGENTOS_SANDBOX_IMAGE=python:3.12
AGENTOS_SANDBOX_TTL=1800                        # 沙箱寿命(秒),到期服务端销毁,重挂重建
# AGENTOS_SANDBOX_TIMEOUT=120                   # 每条命令默认超时(秒)
# AGENTOS_SANDBOX_CPU=1                          # 每沙箱 CPU 上限(docker limits;缺省 1,对齐 SDK 默认)
# AGENTOS_SANDBOX_MEMORY=2Gi                     # 每沙箱内存上限(缺省 2Gi,对齐 SDK 默认)
# AGENTOS_PROTOCOL=http                         # OpenSandbox 服务器协议
# AGENTOS_SERVER_PROXY=true                     # app 直连不到沙箱容器端口时经服务器代理(compose 常态)

# ═════════════════════════════════════════════════════════════════════════════
# Docker Compose 全栈部署（docker-compose.yml）
# 本地开发（uv run aegra dev）用不到以下项；容器化全栈部署时才需要。
# compose 会在 app 容器内覆盖 OPEN_SANDBOX_DOMAIN=opensandbox-server:8080、
# POSTGRES_HOST=postgres、REDIS_URL、AGENTOS_WORKSPACE=/workspace-data，故上方保持本地值即可。
# ═════════════════════════════════════════════════════════════════════════════
PROJECT_NAME=openagentos
PORT=2026
# TAG=                                          # 镜像 tag（deploy 脚本自动注入时间戳；留空=latest）
# PIP_INDEX_URL=https://pypi.org/simple         # 构建期 pip 源（换国内镜像可加速）

# ── Aegra：Postgres（⚠️ 唯一必改：POSTGRES_PASSWORD）──
POSTGRES_PASSWORD=change-me
POSTGRES_DB=agentos
POSTGRES_USER=agentos
POSTGRES_HOST=postgres
POSTGRES_PORT=15432
# DATABASE_URL=postgresql://user:pass@host:5432/agentos   # 托管库（RDS 等）；设了则优先

# ── Aegra：Redis + 鉴权 + 迁移 ──
REDIS_BROKER_ENABLED=true
REDIS_PORT=16379
REDIS_URL=redis://redis:16379/0
# 鉴权：由 aegra.json 的 auth 块（指向 agentos/auth.py）控制，恒生效；此版 Aegra 中 AUTH_TYPE 不控制
# 自定义鉴权开关（noop/custom 等价），保留仅为兼容。auth.py 只标注身份、缺头不拒；数据隔离靠
# assistant_id（上游必传且防覆盖）+ thread_id（Aegra 强制）。详见 README「持久化、记忆与鉴权」。
AUTH_TYPE=noop                                  # 兼容占位；不影响 auth.path 生效
RUN_MIGRATIONS_ON_STARTUP=true                  # 多实例设 false，改用 `aegra db upgrade` 带外迁移

# ── OpenSandbox 服务器（compose）──
OPEN_SANDBOX_PORT=8080                           # 宿主映射端口（仅本机调试连用）

# ── 共享工作区：外挂磁盘上的目录（app 与沙箱共用），唯一真源 ──
# compose 用它做 bind 源，并注入 sandbox.toml 的 allowed_host_paths；须预先 mkdir。Windows 建议用 WSL2 路径。
AGENTOS_WORKSPACE_HOST=/data/openagentos/workspace
# 未挂载保护：启动校验此哨兵文件存在，否则拒启（防外挂盘没挂好时写系统盘）。部署时 `touch <workspace>/.mounted`；留空关闭。
AGENTOS_WORKSPACE_SENTINEL=.mounted
# app 运行身份：默认 0:0(root) 与沙箱一致、可写外挂盘。收紧为非 root 时设外挂盘属主 uid:gid 并 chown 工作区。
AGENTOS_UID=0
AGENTOS_GID=0
