# OpenAgentOS 环境变量。复制为 .env 后填值:cp .env.example .env
#
# OPENAI_* 是全局兜底;每助手的 model/prompt/api_key/base_url 写在 assistant 的
# config.configurable,缺项才回退到这里。MCP servers 写在共享磁盘
# workspace/.deepagent/<assistant_id>/.mcp.json。详见 README。

# ── LLM:OpenAI 兼容网关(Azure OpenAI / LiteLLM / vLLM / Ollama)──
OPENAI_BASE_URL=https://your-gateway.example.com/v1
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4o

# ── 可选:研究子 agent 的联网搜索 ──
# TAVILY_API_KEY=tvly-replace-me

# ── 官方中间件(韧性/成本/合规;retry 默认开,其余默认关)──
# AGENTOS_MODEL_MAX_RETRIES=2      # 模型调用重试次数(0 关)
# AGENTOS_TOOL_MAX_RETRIES=2       # 工具调用重试次数(0 关)
# AGENTOS_TOOL_CALL_LIMIT=         # 每 run 工具调用上限(空=不限)
# AGENTOS_FALLBACK_MODEL=          # 主模型失败时的回退模型(同网关)
# AGENTOS_PII_STRATEGY=off         # PII 脱敏:off/redact/mask/hash/block(邮箱/卡号/IP/MAC)
# AGENTOS_CONTEXT_EDITING=true     # 上下文裁剪(按 token 阈值清旧工具输出)
# AGENTOS_TOOL_SELECTOR_MAX=       # 工具多时用 LLM 每轮选 N 个(空=关)
# 注:每 run 模型调用上限(steps)与自审(review.rubric)是每助手项,放 config.configurable。

# ── 共享磁盘(app 与所有沙箱共用;布局 .deepagent/<aid>/{skills,.mcp.json} + <aid>/<tid>/)──
AGENTOS_WORKSPACE=workspace
# AGENTOS_WORKSPACE_CLAIM=agentos-workspace  # K8s 用 PVC(设了则优先于 host 路径)
# AGENTOS_PUBLIC_URL=/api/aegra             # 反代子路径前缀,一处两用:①下载直链(download_file / /files)②/docs /redoc /openapi 的 root_path(路径部分)。经 BFF 代理设挂载前缀 /api/aegra,独立部署设 https://your-aegra-host,空=根路径。反代须剥该前缀转发(见 nginx location ^~ /aegra/)
# 全栈 compose 另需 AGENTOS_WORKSPACE_HOST(见文件末);本地 aegra dev 缺省=AGENTOS_WORKSPACE 绝对路径。

# ── 长期记忆(默认开;/memories/ 经 CompositeBackend 路由到持久 store,按助手隔离、跨线程)──
# AGENTOS_MEMORY_ENABLED=true

# ── 每线程临时沙箱(OpenSandbox;到期服务端自动销毁,文件在共享磁盘持久)──
# 先启动 OpenSandbox 服务器(依赖 Docker,默认 localhost:8080):
#   uvx opensandbox-server init-config ~/.sandbox.toml --example docker
#   uvx opensandbox-server
OPEN_SANDBOX_DOMAIN=localhost:8080
# OPEN_SANDBOX_API_KEY=            # 服务器需鉴权时填
AGENTOS_SANDBOX_IMAGE=python:3.12-slim   # slim(~150M)拉取快;需构建链就换自建镜像
# SANDBOX_EXECD_IMAGE=opensandbox/execd:v1.0.19  # compose 预拉的 execd,须与 opensandbox/server 匹配
# 注:沙箱镜像与 execd 不是 compose service,由 sandbox-images 服务在 up 时预拉。
# 切勿用 `docker image prune -a` / `docker system prune -a`,会删掉这两个镜像致首次建沙箱超时。
AGENTOS_SANDBOX_TTL=1800           # 沙箱寿命(秒),到期销毁、重挂重建
# AGENTOS_SANDBOX_TIMEOUT=120      # 每条命令默认超时(秒)
# AGENTOS_SANDBOX_CPU=1            # 每沙箱 CPU 上限
AGENTOS_SANDBOX_MEMORY=768Mi       # 每沙箱内存上限;调小以提高 tool-heavy 并发:768Mi→64GB 宿主约 65 个(默认 2Gi 约 25)
# AGENTOS_PROTOCOL=http            # OpenSandbox 服务器协议
# AGENTOS_SERVER_PROXY=true        # 直连不到沙箱端口时经服务器代理(compose 常态)

# ═════════════════════════════════════════════════════════════════════════════
# Docker Compose 全栈部署(docker-compose.yml)—— 本地 aegra dev 用不到以下项。
# compose 在 app 容器内覆盖 OPEN_SANDBOX_DOMAIN / POSTGRES_HOST / REDIS_URL /
# AGENTOS_WORKSPACE,故上方保持本地值即可。
# ═════════════════════════════════════════════════════════════════════════════
PROJECT_NAME=openagentos
PORT=2026
# TAG=                            # 镜像 tag(空=latest;deploy 脚本可注入时间戳)
# PIP_INDEX_URL=https://pypi.org/simple  # 构建期 pip 源(换国内镜像加速)

# ── Postgres(⚠️ 必改:POSTGRES_PASSWORD)──
POSTGRES_PASSWORD=change-me
POSTGRES_DB=agentos
POSTGRES_USER=agentos
POSTGRES_HOST=postgres
POSTGRES_PORT=15432
POSTGRES_MAX_CONNECTIONS=400       # PG 连接硬顶(compose 注入 -c max_connections);须 ≥ 各实例 DB 池连接之和
# DATABASE_URL=postgresql://user:pass@host:5432/agentos  # 托管库(RDS 等);设了则优先于容器 PG

# ── Redis + 鉴权 + 迁移 ──
REDIS_BROKER_ENABLED=true
REDIS_PORT=16379
REDIS_PASSWORD=change-me           # ⚠️ 必改;requirepass 保护发布到宿主的 redis 端口
# app 的 REDIS_URL 由 compose 用 REDIS_PASSWORD + REDIS_PORT 拼装(见 docker-compose.yml),无需在此设。
AUTH_TYPE=custom                   # 对应 aegra.json 的自定义 auth(agentos/auth.py);此版 Aegra 该值不 gate,仅标注意图
RUN_MIGRATIONS_ON_STARTUP=true     # 多实例设 false,改用带外 aegra db upgrade

# ── run 并发/吞吐(仅 REDIS_BROKER_ENABLED=true 生效)──
# 并发上限 = WORKER_COUNT × N_JOBS_PER_WORKER = 5×20 = 100;超出的 run 进 Redis 队列排队,不拒绝。
# 三组须联动放大,否则瓶颈只是前移:worker 数 → DB 池 → Postgres max_connections。
WORKER_COUNT=5
N_JOBS_PER_WORKER=20
# 单实例峰值 PG 连接 ≈ (SQLALCHEMY_POOL_SIZE+MAX_OVERFLOW) + LANGGRAPH_MAX_POOL_SIZE = (30+60)+60 = 150,须 ≤ POSTGRES_MAX_CONNECTIONS。
SQLALCHEMY_POOL_SIZE=30
SQLALCHEMY_MAX_OVERFLOW=60
LANGGRAPH_MIN_POOL_SIZE=10
LANGGRAPH_MAX_POOL_SIZE=60
# ⚠️ tool-heavy 另有天花板:每 run 起 1 沙箱(默认 1CPU/2Gi),100×2Gi=200GB ≫ 64GB 宿主 →
# 实际 tool-heavy 并发 ~25-30(受沙箱宿主内存,非上面的 100),多出的在建沙箱处排队/OOM;
# 纯 LLM/轻任务才吃得满 100。要抬高:加宿主 / 调小 AGENTOS_SANDBOX_MEMORY / 横向加副本。

# ── OpenSandbox 服务器 ──
OPEN_SANDBOX_PORT=8080             # 宿主映射端口(仅本机调试连用)

# ── 共享工作区宿主目录(app 与沙箱共用,唯一真源;须在外挂盘挂载点下、预先 mkdir)──
AGENTOS_WORKSPACE_HOST=/data/openagentos/workspace
AGENTOS_WORKSPACE_SENTINEL=.mounted  # 未挂载哨兵:此文件不在则拒启(防写系统盘);空=关
AGENTOS_UID=0                      # app 运行身份(默认 root,与沙箱一致、可写外挂盘)
AGENTOS_GID=0                      # 非 root 时设为外挂盘属主 uid:gid 并 chown 工作区
