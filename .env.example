# ─────────────────────────────────────────────────────────────────────────────
# OpenAgentOS environment. Copy to `.env` and fill in your values:
#     cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM: OpenAI-compatible gateway (MSPbots gateway / Azure OpenAI / LiteLLM /
#         vLLM / Ollama). The agent talks to {OPENAI_BASE_URL}/chat/completions. ──
OPENAI_BASE_URL=https://your-mspbots-gateway.example.com/v1
OPENAI_API_KEY=replace-me

# Model name as served by the gateway.
AGENTOS_MODEL=gpt-4o
# Optional: a cheaper/faster model for subagents (defaults to AGENTOS_MODEL).
# AGENTOS_SUBAGENT_MODEL=gpt-4o-mini
# Optional: sampling temperature (float).
# AGENTOS_TEMPERATURE=0.2

# ── Optional: web search for the research subagent (research-agent) ──
# Without this, internet_search returns a "not configured" message and the
# agent degrades gracefully.
# TAVILY_API_KEY=tvly-replace-me

# ── Optional: MCP servers (JSON). Enables agentos/mcp_tools.py. ──
# AGENTOS_MCP_SERVERS={"mspbots":{"url":"https://your-host/mcp","transport":"streamable_http"}}

# ── Aegra / Postgres ──
# `uv run aegra dev` provisions PostgreSQL automatically; no value needed for
# local development. For production, configure the database per the Aegra docs:
# https://docs.aegra.dev/guides/deployment
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aegra

# ── 沙箱执行（OpenSandbox；每个 thread 一个临时沙箱，空闲到期销毁）──
# 需先启动 OpenSandbox 服务器：
#   uvx opensandbox-server init-config ~/.sandbox.toml --example docker
#   uvx opensandbox-server                      # 默认 localhost:8080（依赖 Docker）
AGENTOS_SANDBOX_ENABLED=true
OPEN_SANDBOX_DOMAIN=localhost:8080
# OPEN_SANDBOX_API_KEY=...                      # 服务器需鉴权时填
AGENTOS_SANDBOX_IMAGE=python:3.11
AGENTOS_SANDBOX_IDLE_TTL=1800                   # 空闲秒数，超时由 reaper 销毁
AGENTOS_SANDBOX_SWEEP=60                        # reaper 扫描间隔（秒）
# AGENTOS_SANDBOX_TIMEOUT=120                   # 每条命令默认超时（秒）
# AGENTOS_SANDBOX_LIFETIME=1800                 # 沙箱寿命上限（秒，服务端兜底）

# ── 每助手磁盘隔离目录（skills/、mcp.json 按 assistantId 隔离）──
AGENTOS_DATA_DIR=./data
